{
  "@openmrs/esm-patient-chart-app": {
    "disableChangingVisitLocation": false,
    "restrictByVisitLocationTag": true,
    "visitAttributeTypes": [
      {
        "uuid": "de5aef5f-74cc-4d36-b79e-0801f3f55bf6",
        "required": false,
        "displayInThePatientBanner": false
      }
    ],
    "extensionSlots": {
      "patient-chart-dashboard-slot": {
        "add": [
          "dashboard#child-nutrition-program",
          "dashboard#prenatal-program"
        ],
        "configure": {
          "dashboard#child-nutrition-program": {
            "title": "childNutritionTitle",
            "path": "child-nutrition-program",
            "slot": "child-nutrition-program-dashboard-slot",
            "Translation overrides": {
              "en": {
                "childNutritionTitle": "Child Nutrition"
              },
              "fr": {
                "childNutritionTitle": "Malnutrition infantile"
              }
            }
          },
          "dashboard#prenatal-program": {
            "title": "prenatalTitle",
            "path": "prenatal-program",
            "slot": "prenatal-program-dashboard-slot",
            "Translation overrides": {
              "en": {
                "prenatalTitle": "Prenatal"
              },
              "fr": {
                "prenatalTitle": "Prenatal"
              }
            }
          }
        }
      },
      "prenatal-program-dashboard-slot": {
        "add": [
          "active-medications-widget"
        ]
      },
      "child-nutrition-program-dashboard-slot": {
        "add": [
          "active-medications-widget"
        ]
      }
    }
  },
  "@openmrs/esm-patient-tests-app": {
    "additionalTestOrderTypes": [
      {
        "orderTypeUuid": "8d2aff07-55e6-4a4a-8878-72b9eb36a3b8",
        "orderableConceptSets": ["f5b13d49-5ef3-4a33-afdf-6ef22a09d16f"]
      }
    ],
    "showReferenceNumberField": false
  },
  "@openmrs/esm-home-app": {
    "extensionSlots": {
      "homepage-dashboard-slot": {
        "add": [
          "dispensing-dashboard-link"
        ]
      }
    }
  }
}
